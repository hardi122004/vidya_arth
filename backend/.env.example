# PostgreSQL connection
POSTGRES_USER=techtrek
POSTGRES_PASSWORD=techtrek_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=techtrek

# Optionally override the fully-assembled connection string instead of the parts above
# DATABASE_URL=postgresql+psycopg2://techtrek:techtrek_password@localhost:5432/techtrek

# JWT auth
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# CORS - comma separated list of allowed frontend origins, or "*" to allow any origin
# (safe here since auth uses a bearer token, not cookies). Lock this down to
# specific origins before deploying to production.
CORS_ORIGINS=*
